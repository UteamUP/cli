<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v4 manifest for UteamUP CLI Windows MSI installer.
  Build: wix build packaging/msi/uteamup.wxs -o dist/uteamup.msi -arch x64
  Requires WiX Toolset v4+ (https://wixtoolset.org/)
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="UteamUP CLI"
    Manufacturer="UteamUP"
    Version="!(bind.FileVersion.UteamupExe)"
    UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
    Scope="perMachine">

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of UteamUP CLI is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Installation directory -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="UteamUP CLI">
        <Component Id="MainExecutable" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
          <File Id="UteamupExe" Source="!(bindpath.BinDir)\uteamup.exe" KeyPath="yes" />
        </Component>
        <Component Id="ShortNameExecutable" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
          <File Id="UtExe" Source="!(bindpath.BinDir)\uteamup.exe" Name="ut.exe" />
        </Component>
        <Component Id="AddToPath" Guid="D4E5F6A7-B8C9-0123-DEF1-234567890123">
          <Environment Id="PATH" Name="PATH" Value="[INSTALLFOLDER]" Permanent="no"
                       Part="last" Action="set" System="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationShortcutFolder" Name="UteamUP CLI">
        <Component Id="ApplicationShortcut" Guid="E5F6A7B8-C9D0-1234-EF12-345678901234">
          <Shortcut Id="ApplicationStartMenuShortcut"
                    Name="UteamUP CLI"
                    Description="UteamUP CLI — command-line interface"
                    Target="[INSTALLFOLDER]uteamup.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="CleanUpShortcut" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\UteamUP\CLI"
                         Name="installed" Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Features -->
    <Feature Id="Complete" Title="UteamUP CLI" Level="1">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="ShortNameExecutable" />
      <ComponentRef Id="AddToPath" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>

    <!-- UI (minimal wizard) -->
    <UIRef Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
  </Package>
</Wix>
